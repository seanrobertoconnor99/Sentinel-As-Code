                    "confidence": {
                      "type": "string"
                    },
                    "confidenceArea": {
                      "items": {
                        "properties": {
                          "latitude": {
                            "type": "number"
                          },
                          "longitude": {
                            "type": "number"
                          }
                        },
                        "required": [
                          "latitude",
                          "longitude"
                        ],
                        "type": "object"
                      },
