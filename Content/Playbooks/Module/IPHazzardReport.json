{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "IPHazzardReport",
    "description": "Reusable automation module: IPHazzardReport.",
    "lastUpdateTime": "24-03-2026",
    "entities": [],
    "tags": [
      "Module",
      "Source: Sentinel-As-Code"
    ],
    "support": {
      "tier": "community"
    },
    "author": {
      "name": "noodlemctwoodle"
    }
  },
  "parameters": {
    "PlaybookName": {
      "defaultValue": "Module-IPHazzardReport",
      "type": "string"
    },
    "AutomationResourceGroup": {
      "defaultValue": "",
      "type": "string"
    }
  },
  "variables": {},
  "resources": [
    {
      "properties": {
        "provisioningState": "Succeeded",
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "defaultValue": {},
              "type": "Object"
            }
          },
          "triggers": {
            "When_a_HTTP_request_is_received": {
              "type": "Request",
              "kind": "Http",
              "inputs": {
                "schema": {
                  "properties": {
                    "IPAddress": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "actions": {
            "Compose_JSON_Template": {
              "runAfter": {
                "Parse_JSON_Response": [
                  "Succeeded"
                ]
              },
              "type": "Compose",
              "inputs": {
                "Bogon": "@body('Parse_JSON_Response')?['hazardReport']?['isBogon']",
                "Cellular": "@body('Parse_JSON_Response')?['hazardReport']?['isCellular']",
                "City": "@{body('Parse_JSON_Response')?['location']?['city']}",
                "Continent": "@{body('Parse_JSON_Response')?['location']?['continent']}",
                "CountryCode": "@{body('Parse_JSON_Response')?['country']?['isoAlpha2']}",
                "GloballyReachable": "@{body('Parse_JSON_Response')?['isReachableGlobally']}",
                "HostingAsn": "@body('Parse_JSON_Response')?['hazardReport']?['isHostingAsn']",
                "HostingLikelihood": "@{body('Parse_JSON_Response')?['hazardReport']?['hostingLikelihood']}",
                "IPAddress": "@{body('Parse_JSON_Response')?['ip']}",
                "KnownAsMailServer": "@body('Parse_JSON_Response')?['hazardReport']?['isKnownAsMailServer']",
                "KnownAsProxy": "@body('Parse_JSON_Response')?['hazardReport']?['isKnownAsProxy']",
                "KnownAsPublicRouter": "@body('Parse_JSON_Response')?['hazardReport']?['isKnownAsPublicRouter']",
                "KnownAsTorServer": "@body('Parse_JSON_Response')?['hazardReport']?['isKnownAsTorServer']",
                "KnownAsVpn": "@body('Parse_JSON_Response')?['hazardReport']?['isKnownAsVpn']",
                "Organisation": "@{body('Parse_JSON_Response')?['network']?['organisation']}",
                "TotalAddresses": "@body('Parse_JSON_Response')?['network']?['totalAddresses']",
                "Unreachable": "@body('Parse_JSON_Response')?['hazardReport']?['isUnreachable']",
                "iCloudPrivateRelay": "@body('Parse_JSON_Response')?['hazardReport']?['iCloudPrivateRelay']"
              }
            },
            "HTTP_GET_Big_Data_Cloud": {
              "runAfter": {
                "Module-GetSecret": [
                  "Succeeded"
                ]
              },
              "type": "Http",
              "inputs": {
                "uri": "https://api-bdc.net/data/ip-geolocation-full?ip=@{triggerBody()?['IPAddress']}&key=@{body('Module-GetSecret')}",
                "method": "GET"
              }
            },
            "Parse_JSON_Response": {
              "runAfter": {
                "HTTP_GET_Big_Data_Cloud": [
                  "Succeeded"
                ]
              },
              "type": "ParseJson",
              "inputs": {
