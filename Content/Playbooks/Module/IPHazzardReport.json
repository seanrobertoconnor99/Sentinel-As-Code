            "Response": {
              "runAfter": {
                "Compose_JSON_Template": [
                  "Succeeded"
                ]
              },
              "type": "Response",
              "kind": "Http",
              "inputs": {
                "statusCode": 200,
                "body": "@outputs('Compose_JSON_Template')"
              }
            },
            "Module-GetSecret": {
              "runAfter": {},
              "type": "Workflow",
              "inputs": {
                "host": {
                  "workflow": {
                    "id": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('AutomationResourceGroup'), '/providers/Microsoft.Logic/workflows/Module-GetSecret')]"
                  },
                  "triggerName": "When_a_HTTP_request_is_received"
                },
                "body": {
                  "secretName": "BigData-API"
                }
              }
            }
          },
          "outputs": {}
        },
        "accessControl": {
