                                  "application": "@{body('POST_Add_Domain_Indicator')?['application']}",
                                  "calledUsing": "@{triggerBody()?['playbookName']}",
                                  "createdByDisplayName": "@{body('POST_Add_Domain_Indicator')?['createdByDisplayName']}",
