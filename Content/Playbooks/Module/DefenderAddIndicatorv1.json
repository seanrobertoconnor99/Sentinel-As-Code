              "runAfter": {
                "ResponseMessage": [
                  "Succeeded"
                ]
              },
              "type": "Workflow",
              "inputs": {
                "host": {
                  "workflow": {
                    "id": "[concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups/', parameters('AutomationResourceGroup'), '/providers/Microsoft.Logic/workflows/Module-Request-TeamsApproval')]"
                  },
                  "triggerName": "When_an_approval_is_received"
                },
                "body": {
                  "algorithm": "@triggerBody()?['algorithm']",
                  "entityProperties": "@triggerBody()?['entityProperties']",
                  "incidentArmId": "@triggerBody()?['incidentArmId']",
                  "indicatorValue": "@triggerBody()?['indicatorValue']",
                  "playbookName": "@triggerBody()?['playbookName']",
                  "severity": "@triggerBody()?['severity']"
