            }
          },
          "triggers": {
            "When_an_indicator_is_received": {
              "type": "Request",
              "kind": "Http",
              "inputs": {
                "schema": {
                  "properties": {
                    "algorithm": {
                      "type": "string"
                    },
                    "entityProperties": {
                      "type": "string"
                    },
                    "incidentArmId": {
                      "type": "string"
                    },
                    "indicatorValue": {
                      "type": "string"
                    },
                    "playbookName": {
                      "type": "string"
                    },
                    "severity": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            }
          },
          "actions": {
            "Condition": {
              "actions": {},
              "runAfter": {},
              "else": {
                "actions": {
                  "Terminate": {
                    "type": "Terminate",
                    "inputs": {
                      "runStatus": "Cancelled"
                    }
                  }
                }
              },
              "expression": {
                "or": [
                  {
                    "equals": [
                      "@triggerOutputs()?['headers']?['x-ms-workflow-name']",
                      "Entity-DefenderRestrictDomain"
                    ]
                  },
                  {
                    "equals": [
                      "@triggerOutputs()?['headers']?['x-ms-workflow-name']",
                      "Entity-DefenderRestrictFileHash"
                    ]
                  },
                  {
                    "equals": [
                      "@triggerOutputs()?['headers']?['x-ms-workflow-name']",
                      "Entity-DefenderRestrictIP"
                    ]
                  },
                  {
                    "equals": [
                      "@triggerOutputs()?['headers']?['x-ms-workflow-name']",
                      "Entity-DefenderRestrictUrl"
                    ]
                  }
                ]
              },
              "type": "If"
            },
            "ResponseMessage": {
              "runAfter": {
                "Response_Code": [
                  "Succeeded"
                ]
              },
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "ResponseMessage",
                    "type": "array"
                  }
                ]
              }
            },
            "Response_Code": {
