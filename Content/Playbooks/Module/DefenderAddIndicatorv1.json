                                  "inputs": {
                                    "name": "ResponseCode",
                                    "value": "@outputs('POST_Add_SHA265_Indicator')?['statusCode']"
                                  }
                                },
                                "SHA256_Success_Condition": {
                                  "actions": {
                                    "SHA256_Success_Response_Message": {
                                      "type": "AppendToArrayVariable",
                                      "inputs": {
                                        "name": "ResponseMessage",
                                        "value": {
                                          "action": "@{body('POST_Add_SHA265_Indicator')?['action']}",
                                          "application": "@{body('POST_Add_SHA265_Indicator')?['application']}",
