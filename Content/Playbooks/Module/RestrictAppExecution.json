{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "RestrictAppExecution",
    "description": "Reusable automation module: RestrictAppExecution.",
    "lastUpdateTime": "24-03-2026",
    "entities": [],
    "tags": [
      "Module",
      "Source: Sentinel-As-Code"
    ],
    "support": {
      "tier": "community"
    },
    "author": {
      "name": "noodlemctwoodle"
    }
  },
  "parameters": {
    "PlaybookName": {
      "defaultValue": "Module-RestrictAppExecution",
      "type": "string"
    }
  },
  "variables": {
    "MicrosoftDefenderXDRConnectionName": "[concat('MicrosoftDefenderXDR-', parameters('PlaybookName'))]"
  },
  "resources": [
    {
      "properties": {
        "provisioningState": "Succeeded",
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "defaultValue": {},
              "type": "Object"
            }
          },
          "triggers": {
            "When_a_HTTP_request_is_received": {
              "type": "Request",
              "kind": "Http",
              "inputs": {
                "schema": {
                  "properties": {
                    "MachineId": {
                      "type": "string"
                    },
                    "hostName": {
                      "type": "string"
                    },
                    "Comment": {
                      "type": "string"
                    }
                  },
                  "type": "object",
                  "oneOf": [
                    {
                      "required": [
                        "MachineId"
                      ]
                    },
                    {
                      "required": [
                        "hostName"
                      ]
                    }
                  ]
                }
              }
            }
          },
          "actions": {
            "Response": {
              "runAfter": {
                "Actions_-_Restrict_app_execution": [
                  "Succeeded"
                ]
              },
              "type": "Response",
              "kind": "Http",
              "inputs": {
                "statusCode": 200
              }
            },
            "Initialize_DeviceId_Var": {
              "runAfter": {},
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "MDEDeviceId",
                    "type": "string"
                  }
                ]
              }
            },
            "Condition": {
              "actions": {
                "Machines_-_Get_single_machine_hostName": {
                  "type": "ApiConnection",
                  "inputs": {
                    "host": {
                      "connection": {
                        "name": "@parameters('$connections')['wdatp']['connectionId']"
                      }
                    },
                    "method": "get",
                    "path": "/api/machines/@{encodeURIComponent(triggerBody()?['hostName'])}"
                  }
                },
                "Append_to_DeviceId_Var_True": {
                  "runAfter": {
                    "Machines_-_Get_single_machine_hostName": [
                      "Succeeded"
                    ]
                  },
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "MDEDeviceId",
                    "value": "@body('Machines_-_Get_single_machine_hostName')?['id']"
                  }
                }
              },
              "runAfter": {
                "Initialize_DeviceId_Var": [
                  "Succeeded"
                ]
              },
              "else": {
                "actions": {
                  "Machines_-_Get_single_machine_Id": {
                    "type": "ApiConnection",
                    "inputs": {
                      "host": {
                        "connection": {
                          "name": "@parameters('$connections')['wdatp']['connectionId']"
                        }
                      },
                      "method": "get",
                      "path": "/api/machines/@{encodeURIComponent(triggerBody()?['MachineId'])}"
                    }
                  },
                  "Append_to_DeviceId_Var_False": {
                    "runAfter": {
                      "Machines_-_Get_single_machine_Id": [
                        "Succeeded"
                      ]
                    },
                    "type": "AppendToStringVariable",
                    "inputs": {
                      "name": "MDEDeviceId",
                      "value": "@body('Machines_-_Get_single_machine_Id')?['id']"
                    }
                  }
                }
              },
              "expression": {
                "and": [
                  {
                    "equals": [
                      "@triggerBody()?['hostName']",
                      "@null"
                    ]
                  }
                ]
              },
              "type": "If"
            },
            "Actions_-_Restrict_app_execution": {
              "runAfter": {
                "Condition": [
                  "Succeeded"
                ]
              },
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['wdatp']['connectionId']"
                  }
                },
                "method": "post",
                "body": {
                  "Comment": "@triggerBody()?['Comment']"
                },
                "path": "/api/machines/@{encodeURIComponent(variables('MDEDeviceId'))}/restrictCodeExecution"
              }
            }
          },
          "outputs": {}
        },
        "parameters": {
          "$connections": {
            "value": {
              "wdatp": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('MicrosoftDefenderXDRConnectionName'))]",
                "connectionName": "[variables('MicrosoftDefenderXDRConnectionName')]",
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/wdatp')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              }
            }
          }
        },
        "accessControl": {
          "triggers": {
            "allowedCallerIpAddresses": []
          },
          "actions": {
            "allowedCallerIpAddresses": []
          }
        }
      },
      "name": "[parameters('PlaybookName')]",
      "type": "Microsoft.Logic/workflows",
      "location": "[resourceGroup().location]",
      "tags": {
        "Source": "Sentinel-As-Code"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "apiVersion": "2017-07-01",
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('MicrosoftDefenderXDRConnectionName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('MicrosoftDefenderXDRConnectionName')]",
      "location": "[resourceGroup().location]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('MicrosoftDefenderXDRConnectionName')]",
        "customParameterValues": {},
        "parameterValueType": "Alternative",
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/wdatp')]"
        }
      }
    }
  ]
}
