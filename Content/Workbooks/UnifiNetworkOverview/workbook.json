{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspace": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "The Microsoft Sentinel workspace name."
      }
    },
    "workspace-location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region of the workspace."
      }
    }
  },
  "variables": {},
  "resources": [
    {
      "type": "Microsoft.Insights/workbooks",
      "apiVersion": "2022-04-01",
      "name": "0003f7e4-e283-4884-8000-000071e06f60",
      "location": "[parameters('workspace-location')]",
      "kind": "shared",
      "properties": {
        "displayName": "UniFi Network Overview",
        "description": "Provides a comprehensive overview of UniFi network activity including device status, client connections, bandwidth usage, and security events.",
        "serializedData": "{\"version\":\"Notebook/1.0\",\"items\":[{\"type\":1,\"content\":{\"json\":\"## UniFi Network Overview\"}},{\"type\":3,\"content\":{\"version\":\"KqlItem/1.0\",\"query\":\"UniFi_CL | summarize count() by event_type_s\"}}]}",
        "version": "1.0",
        "sourceId": "[concat(resourceGroup().id, '/providers/Microsoft.OperationalInsights/workspaces/', parameters('workspace'))]",
        "category": "Sentinel"
      }
    }
  ]
}